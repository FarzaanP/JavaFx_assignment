<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <MenuBar prefHeight="25.0" prefWidth="597.0" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem mnemonicParsing="false" text="Close" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Edit">
            <items>
              <MenuItem mnemonicParsing="false" text="Delete" />
            </items>
          </Menu>
            <Menu mnemonicParsing="false" text="Themes">
              <items>
                <MenuItem mnemonicParsing="false" text="Action 1" />
              </items>
            </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <TableView prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn prefWidth="50.0" text="ID" />
          <TableColumn prefWidth="50.0" text="FirstName" />
            <TableColumn prefWidth="65.0" text="LastName" />
            <TableColumn prefWidth="65.0" text="Department" />
            <TableColumn prefWidth="65.0" text="Major" />
            <TableColumn prefWidth="65.0" text="Emaill" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
   <right>
      <VBox alignment="TOP_CENTER" prefHeight="512.0" prefWidth="200.0" spacing="5.0" styleClass="right-sidebar" BorderPane.alignment="TOP_CENTER">
         <children>
            <TextField promptText="FirstName" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" top="4.0" />
               </VBox.margin>
            </TextField>
            <TextField promptText="LastName" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" />
               </VBox.margin>
            </TextField>
            <TextField promptText="Major" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" />
               </VBox.margin>
            </TextField>
            <TextField promptText="Department" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" />
               </VBox.margin>
            </TextField>
            <TextField promptText="ID" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" />
               </VBox.margin>
            </TextField>
            <TextField promptText="Email" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="4.0" left="5.0" right="5.0" />
               </VBox.margin>
            </TextField>
            <VBox alignment="BOTTOM_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button maxWidth="150.0" mnemonicParsing="false" text="Edit">
                     <VBox.margin>
                        <Insets bottom="4.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </Button>
                  <Button maxWidth="150.0" mnemonicParsing="false" text="Delete">
                     <VBox.margin>
                        <Insets bottom="4.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </Button>
                  <Button maxWidth="150.0" mnemonicParsing="false" text="Add">
                     <VBox.margin>
                        <Insets bottom="4.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </Button>
                  <Button maxWidth="150.0" mnemonicParsing="false" prefHeight="22.0" prefWidth="150.0" text="Clear" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets bottom="4.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </Button>
               </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </VBox>
         </children>
      </VBox>
   </right>
   <left>
      <VBox styleClass="left-sidebar" BorderPane.alignment="TOP_CENTER">
         <children>
            <ImageView fitHeight="300.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@profile.jpg" />
               </image>
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin></ImageView>
         </children>
      </VBox>
   </left>
   <bottom>
      <HBox prefHeight="25.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>
